rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isTechnician() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'technician';
    }

    function isSubAdmin() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'sub-admin';
    }

    // Get the sub-contractor ID for the current sub-admin user
    function subAdminContractorId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.subContractorId;
    }

    // Users collection - users can read their own data, admins can read all
    // Sub-admins can read technicians in their sub-contractor
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() ||
        (isSubAdmin() && resource.data.subContractorId == subAdminContractorId());
      allow write: if isOwner(userId) || isAdmin();
    }

    // Products collection - public catalog read, admin write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Customers collection
    match /customers/{customerId} {
      allow read: if isOwner(customerId) || isAdmin();
      allow write: if isOwner(customerId) || isAdmin();
    }

    // Orders collection - restricted reads, validated creates
    match /orders/{orderId} {
      // Customers see their own orders, technicians see pending + their own, admins see all
      // Sub-admins see orders assigned to their sub-contractor
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.customerId == request.auth.uid) ||
        (isTechnician() && (resource.data.status == 'pending' || resource.data.technicianId == request.auth.uid)) ||
        (isSubAdmin() && resource.data.subContractorId == subAdminContractorId());

      // Only allow create if customerId matches the authenticated user
      allow create: if isAuthenticated() &&
        request.resource.data.customerId == request.auth.uid;

      allow update, delete: if isAdmin();

      // Customers can update their own orders (rating, cancellation)
      // But cannot modify scheduling fields (admin-only)
      allow update: if isAuthenticated() &&
        resource.data.customerId == request.auth.uid &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['scheduledAt', 'estimatedDurationMinutes']);

      // Technicians can update pending orders (accept) or their own assigned orders
      // But cannot modify scheduling fields (admin-only)
      allow update: if isTechnician() &&
        (resource.data.status == 'pending' ||
         resource.data.technicianId == request.auth.uid) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['scheduledAt', 'estimatedDurationMinutes']);
    }

    // Sub-contractors collection - admins + sub-admins (own contractor only)
    match /subContractors/{contractorId} {
      allow read: if isAdmin() ||
        (isSubAdmin() && contractorId == subAdminContractorId());
      allow write: if isAdmin();
    }

    // Transactions collection - validated create, admin manage
    match /transactions/{transactionId} {
      allow read: if isAdmin();
      // Enforce performedBy matches the authenticated user
      allow create: if isAuthenticated() &&
        request.resource.data.performedBy == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Services collection - public read, admin write
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Customer History collection
    match /customerHistory/{historyId} {
      allow read: if isAuthenticated() && resource.data.customerId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.customerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Student data
    match /students/{studentId} {
      allow read: if isOwner(studentId);
      allow write: if isOwner(studentId);
    }

    // Lessons
    match /lessons/{lessonId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Problem sets
    match /problemSets/{problemSetId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // User progress
    match /progress/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // Devices collection — registered Ezer units
    // Any technician can read devices (needed for QR scan maintenance workflow)
    match /devices/{deviceId} {
      allow read: if isAdmin() || isTechnician() ||
        (isAuthenticated() && resource.data.customerId == request.auth.uid);
      allow create: if isTechnician() &&
        request.resource.data.technicianId == request.auth.uid;
      // Admins can update any field. Technicians can only update the
      // maintenance-denormalization fields written by completeMaintenance().
      allow update: if isAdmin() || (
        isTechnician() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastEzerMaintenanceAt',
          'nextEzerMaintenanceDue',
          'lastFilterReplacementAt',
          'nextFilterReplacementDue'
        ])
      );
      allow delete: if isAdmin();
    }

    // Notifications collection — in-app notifications per user
    match /notifications/{notificationId} {
      // User reads own notifications, admin reads all
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid);
      // Any authenticated user can create notifications (server-side via Cloud Functions runs as admin)
      allow create: if isAuthenticated();
      // User can update own notification (mark as read), admin can update any
      allow update: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Reviews collection — customer ratings for orders
    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.customerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Maintenance Schedules collection
    // Any technician can read and update schedules (needed for QR scan maintenance workflow)
    // Customers can read schedules (needed for customer device portal)
    match /maintenanceSchedules/{scheduleId} {
      allow read: if isAdmin() || isTechnician() || isAuthenticated();
      allow create: if isTechnician() &&
        request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin() || isTechnician();
      allow delete: if isAdmin();
    }

    // Maintenance Visits collection
    // Technicians can create and read visits
    // Admins can read and write all visits
    // Customers can read visits for their devices
    match /maintenanceVisits/{visitId} {
      allow read: if isAdmin() || isTechnician() || isAuthenticated();
      allow create: if isTechnician();
      allow update, delete: if isAdmin();
    }

    // Inventory collection — admin only
    match /inventory/{itemId} {
      allow read, write: if isAdmin();
    }

    // Stock Adjustments collection — admin only
    match /stockAdjustments/{adjustmentId} {
      allow read, write: if isAdmin();
    }

    // QR Codes collection — admin only
    match /qrCodes/{qrCodeId} {
      allow read, write: if isAdmin();
    }

    // Mail collection — used by Firebase Trigger Email extension
    // Authenticated users can create emails; extension handles read/delete
    match /mail/{mailId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

